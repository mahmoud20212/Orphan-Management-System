#tabWidget_2::tab {
    padding: 5px 10px;
}

/* =======================
   QDoubleSpinBox
======================= */
QDoubleSpinBox {
    padding: 6px 8px;
    padding-right: 24px; /* مساحة لأزرار الزيادة */
    border-radius: 6px;
    border: 1px solid #d1d5db;
    background-color: #ffffff;
    color: #111827;
    font-size: 13px;
}

/* عند التركيز */
QDoubleSpinBox:focus {
    border: 1px solid #2d6cdf;
}

/* تعطيل */
QDoubleSpinBox:disabled {
    background-color: #f3f4f6;
    color: #9ca3af;
    border: 1px solid #e5e7eb;
}
